# AI Clipper Environment Variables
# Copy this to .env and fill in your values

# OpenAI API Key (for --ai chatgpt)
OPENAI_API_KEY=

# OpenRouter API Key (for --ai openrouter)
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Whisper model directory
# WHISPER_MODEL_DIR=
